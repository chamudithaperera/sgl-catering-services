generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Message {
  id            Int      @id @default(autoincrement())
  customerName  String   @map("customer_name")
  phone         String
  eventType     String   @map("event_type")
  serviceNeeded String   @map("service_needed")
  eventDate     String   @map("event_date")
  guestCount    String   @map("guest_count")
  location      String
  message       String   @db.Text
  isRead        Boolean  @default(false) @map("is_read")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model ContactDetails {
  id            Int      @id
  phone         String
  whatsapp      String
  email         String
  address       String
  businessHours String   @map("business_hours")
  mapUrl        String   @map("map_url")
  facebookUrl   String   @map("facebook_url")
  instagramUrl  String   @map("instagram_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("contact_details")
}

model CateringCatergory {
  id          Int            @id @default(autoincrement())
  title       String
  shortLabel  String         @map("short_label")
  description String         @db.Text
  imageUrl    String         @map("image_url")
  highlights  Json
  sortOrder   Int            @default(0) @map("sort_order")
  menus       CateringMenu[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("catering_catergories")
}

model CateringMenu {
  id            Int                @id @default(autoincrement())
  categoryId    Int?               @map("category_id")
  category      CateringCatergory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  summary       String             @db.Text
  priceLabel    String             @map("price_label")
  includedItems Json               @map("included_items")
  featured      Boolean            @default(false)
  ctaLabel      String             @map("cta_label")
  sortOrder     Int                @default(0) @map("sort_order")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@map("catering_menus")
}

model RentalBundle {
  id         Int      @id @default(autoincrement())
  name       String
  summary    String
  priceLabel String   @default("මිල විමසන්න") @map("price_label")
  items      Json
  ctaLabel   String   @map("cta_label")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("rental_bundles")
}

model RentalItem {
  id                Int      @id @default(autoincrement())
  name              String
  description       String   @db.Text
  category          String
  imageUrl          String   @map("image_url")
  priceLabel        String   @map("price_label")
  availableQuantity Int      @map("available_quantity")
  status            String
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("rental_items")
}

model Gallery {
  id        Int      @id @default(autoincrement())
  title     String
  category  String
  imageUrl  String   @map("image_url")
  featured  Boolean  @default(false)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gallery")
}

model Review {
  id           Int      @id @default(autoincrement())
  customerName String   @map("customer_name")
  eventType    String   @map("event_type")
  rating       Int
  quote        String   @db.Text
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("reviews")
}
