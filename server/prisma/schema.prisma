generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteConfig {
  id                Int      @id
  companyName       String
  heroBadge         String
  heroTitleLineOne  String
  heroTitleLineTwo  String
  heroDescription   String   @db.Text
  aboutHeading      String
  aboutIntro        String   @db.Text
  aboutBody         String   @db.Text
  contactHeading    String
  contactDescription String  @db.Text
  phone             String
  whatsapp          String
  email             String
  address           String
  businessHours     String
  mapUrl            String
  facebookUrl       String
  instagramUrl      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Benefit {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  icon        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  icon        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EventCategory {
  id           Int           @id @default(autoincrement())
  title        String
  shortLabel   String
  description  String        @db.Text
  imageUrl     String
  highlights   Json
  sortOrder    Int           @default(0)
  foodPackages FoodPackage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model FoodPackage {
  id            Int      @id @default(autoincrement())
  categoryId    Int?
  category      EventCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  summary       String   @db.Text
  priceLabel    String
  includedItems Json
  featured      Boolean  @default(false)
  ctaLabel      String
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RentalItem {
  id                Int      @id @default(autoincrement())
  name              String
  description       String   @db.Text
  category          String
  imageUrl          String
  priceLabel        String
  availableQuantity Int
  status            String
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RentalPrice {
  id         Int      @id @default(autoincrement())
  item       String
  priceLabel String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RentalPackage {
  id         Int      @id @default(autoincrement())
  name       String
  summary    String
  priceLabel String   @default("මිල විමසන්න")
  items      Json
  ctaLabel   String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model GalleryItem {
  id         Int      @id @default(autoincrement())
  title      String
  category   String
  imageUrl   String
  featured   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Review {
  id           Int      @id @default(autoincrement())
  customerName String
  eventType    String
  rating       Int
  quote        String   @db.Text
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id            Int      @id @default(autoincrement())
  customerName  String
  phone         String
  eventType     String
  serviceNeeded String
  eventDate     String
  guestCount    String
  location      String
  message       String   @db.Text
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
}
